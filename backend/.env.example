# Recon Pulse Environment Configuration Example
# Copy this file to .env and fill in your keys

# Google PageSpeed Insights API Key (optional but recommended for rate limits)
PAGESPEED_API_KEY=your_key_here

# GNews API Key for website news mentions
GNEWS_API_KEY=your_key_here

# GitHub Personal Access Token (for checking repo/follower counts)
GITHUB_API_KEY=your_key_here

# Puppeteer service URL (for generating domain screenshots)
PUPPETEER_SERVICE_URL=http://localhost:3001

# n8n webhook URL
N8N_WEBHOOK_URL=http://localhost:5678/webhook/report
